df = pd.read_csv(r'C:\Users\roshi\Downloads\archive\credit_card_fraud_dataset.csv')

# 1. Basic fraud statistics
print("=== FRAUD OVERVIEW ===")
print(df['IsFraud'].value_counts())
fraud_percentage = (df['IsFraud'].sum() / len(df)) * 100
print(f"Fraud percentage: {fraud_percentage:.2f}%")

# 2. Amount analysis - fraud vs legitimate
print("\n=== AMOUNT ANALYSIS ===")
print("Fraud transactions:")
print(df[df['IsFraud']==1]['Amount'].describe())
print("\nLegitimate transactions:")
print(df[df['IsFraud']==0]['Amount'].describe())

# 3. Transaction Type analysisaa
print("\n=== TRANSACTION TYPE ANALYSIS ===")
fraud_by_type = df.groupby('TransactionType')['IsFraud'].agg(['sum', 'count', 'mean'])
fraud_by_type.columns = ['Fraud_Count', 'Total_Transactions', 'Fraud_Rate']
print(fraud_by_type.sort_values('Fraud_Rate', ascending=False))

# 4. Location analysis
print("\n=== TOP 10 LOCATIONS WITH HIGHEST FRAUD ===")
fraud_by_location = df.groupby('Location')['IsFraud'].agg(['sum', 'count', 'mean'])
fraud_by_location.columns = ['Fraud_Count', 'Total_Transactions', 'Fraud_Rate']
print(fraud_by_location.sort_values('Fraud_Count', ascending=False).head(10))

# 5. Merchant analysis
print("\n=== TOP 10 MERCHANTS WITH HIGHEST FRAUD ===")
fraud_by_merchant = df.groupby('MerchantID')['IsFraud'].agg(['sum', 'count', 'mean'])
fraud_by_merchant.columns = ['Fraud_Count', 'Total_Transactions', 'Fraud_Rate']
print(fraud_by_merchant.sort_values('Fraud_Count', ascending=False).head(10))
